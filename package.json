{
  "name": "defog-extension",
  "displayName": "Defog — Auto Text & Word Replacer",
  "version": "1.0.0",
  "description": "Automatically replace text, words, UUIDs, and patterns with readable labels on any website. Open source.",
  "author": "Andy Young <andyluyoung@gmail.com>",
  "scripts": {
    "dev": "concurrently \"plasmo dev\" \"tailwindcss -i popup/index.css -o popup/index.built.css --watch\"",
    "build": "tailwindcss -i popup/index.css -o popup/index.built.css --minify && plasmo build",
    "build:firefox": "tailwindcss -i popup/index.css -o popup/index.built.css --minify && plasmo build --target=firefox-mv2",
    "package": "plasmo package",
    "package:firefox": "plasmo package --target=firefox-mv2",
    "format": "prettier --write .",
    "lint": "eslint . --fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "@plasmohq/storage": "^1.15.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "plasmo": "0.90.5",
    "radix-ui": "^1.4.3",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.71.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@tailwindcss/cli": "^4.2.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "3.2.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn": "^4.0.0",
    "typescript": "5.3.3",
    "typescript-eslint": "^8.56.1"
  },
  "lint-staged": {
    "*.{ts,tsx,mjs}": "eslint --fix",
    "*": "prettier --write --ignore-unknown"
  },
  "manifest": {
    "permissions": [
      "storage"
    ]
  }
}
