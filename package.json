{
  "name": "defog",
  "displayName": "Defog",
  "version": "0.0.1",
  "description": "Map UUIDs and text patterns to human-readable labels across all webpages.",
  "author": "Andy Young <andyluyoung@gmail.com>",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "plasmo": "0.90.5",
    "postcss": "^8.5.8",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "prettier": "3.2.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "5.3.3",
    "typescript-eslint": "^8.56.1"
  },
  "manifest": {
    "host_permissions": [
      "http://*/*",
      "https://*/*"
    ],
    "permissions": [
      "storage"
    ]
  }
}
